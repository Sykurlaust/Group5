rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /listings/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /conversations/{conversationId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;

      allow create: if request.auth != null
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.renterId is string
        && request.resource.data.landlordId is string
        && request.resource.data.renterId in request.resource.data.participants
        && request.resource.data.landlordId in request.resource.data.participants;

      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;

      allow delete: if false;
    }

    match /conversations/{conversationId}/messages/{messageId} {
      allow read: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;

      allow create: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
        && request.resource.data.senderId == request.auth.uid;

      allow update, delete: if false;
    }
  }
}
